generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id           String    @id @default(cuid())
  agencyId     String
  agency       Agency    @relation(fields: [agencyId], references: [id])
  email        String    @unique
  passwordHash String
  name         String?
  role         String    @default("member")
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// 법정동(시도/시군구/읍면동) — VWorld 적재. 동 선택 → naverCode로 네이버 complex/region 조회.
model LegalDivision {
  code        String  @id          // VWorld 코드 (시도 2 / 시군구 5 / 읍면동 8자리)
  level       String               // SIDO | SIGUNGU | EMD
  name        String               // 레벨 명칭 (경기도 / 수원시 장안구 / 정자동)
  fullName    String               // 전체 명칭 (경기도 수원시 장안구 정자동)
  sidoCode    String               // 상위 시도 코드 (2)
  sigunguCode String?              // 상위 시군구 코드 (5) — EMD만
  naverCode   String? @unique      // EMD: emd_cd + "00" (10) = 네이버 eupLegalDivisionNumber
  lng         Float?               // 대표 좌표(중심점)
  lat         Float?

  @@index([level])
  @@index([sidoCode])
  @@index([sigunguCode])
}

// 단지 (네이버 수집 캐시, 전역 공유) — 기본 정보만
model Complex {
  id              String    @id @default(cuid())
  complexNumber   String    @unique // 네이버 단지번호
  name            String
  type            String? // A01 아파트 / A02 주상복합
  totalHouseholds Int?
  approvalDate    String? // 사용승인일 YYYYMMDD
  regionCode      String? // 수집된 동 코드 (naverCode)
  raw             Json?
  fetchedAt       DateTime  @default(now())
  articles        Article[]

  @@index([regionCode])
}

// 매물 (네이버 수집 캐시, 전역 공유) — 기본 정보만
model Article {
  id            String   @id @default(cuid())
  articleNumber String   @unique
  complexId     String
  complex       Complex  @relation(fields: [complexId], references: [id], onDelete: Cascade)
  tradeType     String // A1 매매 / B1 전세 / B2 월세
  price         BigInt? // 거래금액(원): 매매가 또는 보증금
  rentPrice     BigInt? // 월세
  areaExclusive Float? // 전용면적
  areaSupply    Float? // 공급면적
  floor         String? // "2/23"
  realtorName   String?
  raw           Json?
  fetchedAt     DateTime @default(now())

  @@index([complexId])
}
